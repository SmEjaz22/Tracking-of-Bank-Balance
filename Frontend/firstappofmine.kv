# Practicing

# GridLayoutExample:
        # Class rule only (<ClassName>) when Python returns instance
        # Root rule only (ClassName:) when Python returns nothing
# <GridLayoutExample>:
    # rows: 2
    # cols:1
    # size_hint: (1, None) # To use width and height, size_hint must be set to None.
    
    # gridlayout doesnot allow the pos_hint values in kv file. But uses the cols/rows feature. Otherwise the things wll override eachother.

    # # height: "360dp"
    # Label:
    #     text: "Hi Grid"
    # Label:
    #     text: "Hi Grid"
    # Label:
    #     text: "Hi Grid"
    # Label:
    #     text: "Hi Grid"
    
    # GridLayout:
    # Label:
    #     text: "Total Mon"
    # AnchorLayout:
    #     anchor_x: "left"
    #     Label:
    #         text: "Sal"
    # AnchorLayout:
    #     anchor_x: "right"
    #     Label:
    #         text: "Sav"
    # AnchorLayout:
    #     anchor_x: "center"
    #     Label:
    #         text: "Oth"
<GridLayoutExample>:
    rows: 4
    cols: 1
    
    # Row 1: Title
    Label:
        text: root.mytotal + root.mytotalvalue + "$"
        size_hint_y: None
        height: 50
        on_touch_down: if self.collide_point(*args[1].pos): root.showtotal()
# EXPLANATION:
#self.collide_point(*args[1].pos)
#         ↑         ↑       ↑
#         │         │       └── Gets (x,y) position tuple from touch
#         │         └── Unpacks the tuple into x,y arguments
#         └── Checks if (x,y) is inside this widget




    # Label:
    #     text: root.mytotalvalue
    
    # Row 2: Three buttons with text below
    BoxLayout: # The boc layout automatically arranges its childs to 'left', 'center' & 'right'
        size_hint_y: None
        height: 150
        
        # Left button + text
        AnchorLayout:
            anchor_x: 'center'
            BoxLayout:
                orientation: 'vertical'
                size_hint: None, None
                size: 150, 140
                Button:
                    text: "Sal"
                    size_hint_y: 0.7
                    on_press: root.showsalary()
                Label:
                    text: root.mysalary
                    size_hint_y: 0.3
                    halign: 'center'
        
        # Center button + text (same pattern)
        AnchorLayout:
            anchor_x: 'center'
            BoxLayout:
                orientation: 'vertical'
                size_hint: None, None
                size: 150, 140
                Button:
                    text: "Sav"
                    size_hint_y: 0.7
                    on_press: root.showsaving()
                Label:
                    text: root.mysaving
                    size_hint_y: 0.3
                    halign: 'center'
        
        # Right button + text (same pattern)
        AnchorLayout:
            anchor_x: 'center'
            BoxLayout:
                orientation: 'vertical'
                size_hint: None, None
                size: 150, 140
                Button:
                    text: "Oth"
                    size_hint_y: 0.7
                    on_press: root.showothers()
                Label:
                    text: root.myothers
                    size_hint_y: 0.3
                    halign: 'center'
<BoxLayoutExample>:
    orientation: 'vertical'

    Button:
        text: "Login"
        color: (1,.5,1,1)
        background_color: (1,.5,1,1)
    
    Label:
        text: "Hi Box"
        # size_hint: (None, None)
        # width: "1000dp"
        # height: "50dp"
    Label:
        text: "Hi Box"
    Label:
        text: "Hi Box"
    Label:
        text: "Hi Box"








